<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             
             x:Class="IT3048FinalNationalParksApp.Auth.MainPage">
    <VerticalStackLayout
        Spacing="50">
        <Label Text="Tri-State Trails"
               FontSize="Header"
               FontAttributes="Bold"
               HorizontalOptions="Center"/>
        <Button Text="Sign Up"
                Clicked="SignUp_Clicked"
                FontSize="Large"
                WidthRequest="200"
                HeightRequest="50"/>
        <Button Text="Log In"
                Clicked="LogIn_Clicked"
                FontSize="Large"
                WidthRequest="200"
                HeightRequest="50"/>
    </VerticalStackLayout>

</ContentPage>
