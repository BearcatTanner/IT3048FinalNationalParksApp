<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage x:Class="IT3048FinalNationalParksApp.Auth.SignUpPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#F5F0E8">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="0">

            <!-- Logo / Title -->
            <Label Text="Tri-State Trails"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="#1B3A2D"
                   HorizontalOptions="Center" />
            <Label Text="Create Account"
                   FontSize="20"
                   TextColor="#666666"
                   HorizontalOptions="Center"
                   Margin="0,8,0,40" />

            <!-- First Name -->
            <Label Text="First Name" FontSize="13" TextColor="#1B3A2D" Margin="0,0,0,4" />
            <Frame Padding="12,0" CornerRadius="8" BorderColor="#E0D9CE"
                   BackgroundColor="White" HasShadow="False" Margin="0,0,0,16">
                <Entry Text="{Binding Firstname}"
                       Placeholder="First name"
                       PlaceholderColor="#BBBBBB"
                       TextColor="#1B3A2D"
                       BackgroundColor="Transparent"
                       HeightRequest="44" />
            </Frame>

            <!-- Last Name -->
            <Label Text="Last Name" FontSize="13" TextColor="#1B3A2D" Margin="0,0,0,4" />
            <Frame Padding="12,0" CornerRadius="8" BorderColor="#E0D9CE"
                   BackgroundColor="White" HasShadow="False" Margin="0,0,0,16">
                <Entry Text="{Binding Lastname}"
                       Placeholder="Last name"
                       PlaceholderColor="#BBBBBB"
                       TextColor="#1B3A2D"
                       BackgroundColor="Transparent"
                       HeightRequest="44" />
            </Frame>

            <!-- Username -->
            <Label Text="Username" FontSize="13" TextColor="#1B3A2D" Margin="0,0,0,4" />
            <Frame Padding="12,0" CornerRadius="8" BorderColor="#E0D9CE"
                   BackgroundColor="White" HasShadow="False" Margin="0,0,0,16">
                <Entry Text="{Binding Username}"
                       Placeholder="Choose a username"
                       PlaceholderColor="#BBBBBB"
                       TextColor="#1B3A2D"
                       BackgroundColor="Transparent"
                       HeightRequest="44" />
            </Frame>

            <!-- Email -->
            <Label Text="Email" FontSize="13" TextColor="#1B3A2D" Margin="0,0,0,4" />
            <Frame Padding="12,0" CornerRadius="8" BorderColor="#E0D9CE"
                   BackgroundColor="White" HasShadow="False" Margin="0,0,0,16">
                <Entry Text="{Binding Email}"
                       Placeholder="your@email.com"
                       PlaceholderColor="#BBBBBB"
                       TextColor="#1B3A2D"
                       Keyboard="Email"
                       BackgroundColor="Transparent"
                       HeightRequest="44" />
            </Frame>

            <!-- Password -->
            <Label Text="Password" FontSize="13" TextColor="#1B3A2D" Margin="0,0,0,4" />
            <Frame Padding="12,0" CornerRadius="8" BorderColor="#E0D9CE"
                   BackgroundColor="White" HasShadow="False" Margin="0,0,0,16">
                <Entry Text="{Binding Password}"
                       Placeholder="Create a password"
                       PlaceholderColor="#BBBBBB"
                       TextColor="#1B3A2D"
                       IsPassword="True"
                       BackgroundColor="Transparent"
                       HeightRequest="44" />
            </Frame>

            <!-- Confirm Password -->
            <Label Text="Confirm Password" FontSize="13" TextColor="#1B3A2D" Margin="0,0,0,4" />
            <Frame Padding="12,0" CornerRadius="8" BorderColor="#E0D9CE"
                   BackgroundColor="White" HasShadow="False" Margin="0,0,0,8">
                <Entry Text="{Binding ConfirmPassword}"
                       Placeholder="Repeat your password"
                       PlaceholderColor="#BBBBBB"
                       TextColor="#1B3A2D"
                       IsPassword="True"
                       BackgroundColor="Transparent"
                       HeightRequest="44" />
            </Frame>

            <!-- Error Message -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   FontSize="12"
                   IsVisible="{Binding HasError}"
                   Margin="0,0,0,8" />

            <!-- Sign Up Button -->
            <Button Text="Sign Up"
                    Command="{Binding SignUpCommand}"
                    BackgroundColor="#1B3A2D"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="10"
                    HeightRequest="50"
                    Margin="0,16,0,0" />

            <!-- Go to Login -->
            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,20,0,0" Spacing="4">
                <Label Text="Already have an account?"
                       FontSize="13"
                       TextColor="#666666"
                       VerticalOptions="Center" />
                <Label Text="Log In"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="#1B3A2D"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
