<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage x:Class="IT3048FinalNationalParksApp.MainApp.PassportPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:IT3048FinalNationalParksApp.Views"
             Shell.TabBarIsVisible="True"
             BackgroundColor="#F5F0E8">

    <Shell.TitleView>
        <Label Text="Tri-State Trails"
               FontSize="22"
               FontAttributes="Bold"
               TextColor="#1B3A2D"
               VerticalOptions="Center"
               Margin="4,0,0,0" />
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,*">

        <!-- Sub-header -->
        <VerticalStackLayout Grid.Row="0"
                             Padding="20,16,20,8"
                             BackgroundColor="#F5F0E8">
            <Label Text="Passport"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#1B3A2D" />
            <Label Text="{Binding StampCount, StringFormat='{0} parks visited'}"
                   FontSize="13"
                   TextColor="#888888"
                   Margin="0,2,0,0" />
        </VerticalStackLayout>

        <!-- Stamps Grid -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,8,16,24">

                <!-- Empty State -->
                <VerticalStackLayout IsVisible="{Binding HasNoStamps}"
                                     HorizontalOptions="Center"
                                     Spacing="12"
                                     Margin="0,60,0,0">
                    <Label Text="📖" FontSize="48" HorizontalOptions="Center" />
                    <Label Text="Your passport is empty"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#1B3A2D"
                           HorizontalOptions="Center" />
                    <Label Text="Visit parks and log them to collect stamps"
                           FontSize="13"
                           TextColor="#9E9E9E"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- 3-column stamp grid -->
                <CollectionView ItemsSource="{Binding Stamps}"
                                IsVisible="{Binding HasStamps}"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical"
                                         Span="3"
                                         HorizontalItemSpacing="10"
                                         VerticalItemSpacing="20" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="views:PassportStamp">
                            <VerticalStackLayout Spacing="6"
                                                 HorizontalOptions="Center">

                                <!-- Stamp circle -->
                                <Frame WidthRequest="90"
                                       HeightRequest="90"
                                       CornerRadius="45"
                                       Padding="0"
                                       HasShadow="False"
                                       BorderColor="#1B3A2D"
                                       BackgroundColor="White"
                                       HorizontalOptions="Center">
                                    <Grid>
                                        <!-- Visited -->
                                        <Image Source="{Binding StampImageUrl}"
                                               Aspect="AspectFill"
                                               IsVisible="{Binding IsVisited}" />

                                        <!-- Not visited -->
                                        <BoxView Color="#E8E3DA"
                                                 IsVisible="{Binding IsNotVisited}"
                                                 CornerRadius="43" />
                                        <Label Text="?"
                                               FontSize="28"
                                               TextColor="#BBBBBB"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               IsVisible="{Binding IsNotVisited}" />
                                    </Grid>
                                </Frame>

                                <!-- Park name -->
                                <Label Text="{Binding ParkName}"
                                       FontSize="11"
                                       TextColor="#1B3A2D"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       MaxLines="2"
                                       LineBreakMode="WordWrap"
                                       WidthRequest="90" />

                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
