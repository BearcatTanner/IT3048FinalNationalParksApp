<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage x:Class="IT3048FinalNationalParksApp.MainApp.ParkDetailsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:IT3048FinalNationalParksApp.Views"
             Shell.TabBarIsVisible="True"
             BackgroundColor="#F5F0E8">

    <Shell.TitleView>
        <Label Text="Tri-State Trails"
               FontSize="22"
               FontAttributes="Bold"
               TextColor="#1B3A2D"
               VerticalOptions="Center"
               Margin="4,0,0,0" />
    </Shell.TitleView>

    <Shell.BackButtonBehavior>
        <BackButtonBehavior Command="{Binding GoBackCommand}"
                            IsEnabled="True" />
    </Shell.BackButtonBehavior>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Hero image -->
            <Grid HeightRequest="240">
                <Image Source="{Binding ImageUrl}"
                       ToolTipProperties.Text="{Binding ImageAltText}"
                       Aspect="AspectFill"
                       HeightRequest="240" />

                <!-- Dark scrim so the name is always legible -->
                <BoxView Color="Black"
                         Opacity="0.35"
                         HeightRequest="240" />

                <!-- Park name overlay -->
                <Label Text="{Binding ParkName}"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="White"
                       VerticalOptions="End"
                       HorizontalOptions="Start"
                       Margin="20,0,20,18"
                       LineBreakMode="WordWrap" />
            </Grid>

            <!-- Details card -->
            <VerticalStackLayout Padding="20,20,20,32"
                                 Spacing="16">

                <!-- Location row -->
                <HorizontalStackLayout Spacing="8">
                    <Label Text="📍"
                           FontSize="16"
                           VerticalOptions="Start"
                           Margin="0,2,0,0" />
                    <Label Text="{Binding Location}"
                           FontSize="14"
                           TextColor="#555555"
                           VerticalOptions="Start"
                           LineBreakMode="WordWrap" />
                </HorizontalStackLayout>

                <!-- Mark as Visited button -->
                <Button Text="{Binding VisitedButtonText}"
                        Command="{Binding MarkVisitedCommand}"
                        BackgroundColor="{Binding VisitedButtonColor}"
                        TextColor="{Binding VisitedButtonTextColor}"
                        FontSize="15"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        HeightRequest="50"
                        HorizontalOptions="Fill" />

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         Color="#E0D9CE" />

                <!-- Description header -->
                <Label Text="About this Park"
                       FontSize="17"
                       FontAttributes="Bold"
                       TextColor="#1B3A2D" />

                <!-- Description body -->
                <Label Text="{Binding Description}"
                       FontSize="14"
                       TextColor="#444444"
                       LineBreakMode="WordWrap" />

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
