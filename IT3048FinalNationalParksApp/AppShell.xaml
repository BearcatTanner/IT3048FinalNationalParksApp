<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="IT3048FinalNationalParksApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:IT3048FinalNationalParksApp.MainApp"
    Shell.FlyoutBehavior="Disabled"
    Title="IT3048FinalNationalParksApp">

    <TabBar Route="MainApp">
        <ShellContent Route="Home" Title="Home" ContentTemplate="{DataTemplate local:HomePage}" />
        <ShellContent Title="Search" ContentTemplate="{DataTemplate local:SearchPage}" />
        <ShellContent Title="Passport" ContentTemplate="{DataTemplate local:PassportPage}" />
        <ShellContent Route="Profile" Title="Profile" ContentTemplate="{DataTemplate local:ProfilePage}" />
    </TabBar>

</Shell>
